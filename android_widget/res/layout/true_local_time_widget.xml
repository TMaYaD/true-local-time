<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tlt_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/true_local_time_widget_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="12dp">

    <TextClock
        android:id="@+id/tlt_widget_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:format12Hour="EEE, d MMM"
        android:format24Hour="EEE, d MMM"
        android:textColor="#FFFFFF"
        android:textSize="13sp" />

    <TextClock
        android:id="@+id/tlt_widget_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFeatureSettings="tnum"
        android:format12Hour="HH:mm"
        android:format24Hour="HH:mm"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/tlt_widget_globe"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/tlt_widget_longitude"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#B3FFFFFF"
        android:textSize="11sp" />
</LinearLayout>
